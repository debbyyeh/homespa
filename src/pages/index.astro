---
import Home from "../components/Home.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <Home />
</Layout>

<style is:global>
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    /* letter-spacing: 0.7em; */
    /* background-color: rgb(195,167,108); */
    font-family:
      Gilda Display,
      Noto Sans TC,
      sans-serif;
  }
  a {
    text-decoration: none;
  }
  ul {
    list-style-type: none;
    margin: auto;
    padding: 0;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  .star {
    width: 29px;
    height: 29px;
    align-self: flex-start;
  }
  .section-title {
    margin-bottom: 30px;
    display: flex;
    align-items: baseline;
    justify-content: center;
  }
  .f65-36 {
    margin-right: 10px;
    font-size: 4.0625rem;
  }
  .f30-25 {
    font-size: 1.875rem;
  }
  .f24-20 {
    font-size: 1.5rem;
  }
  .f26-20 {
    font-size: 1.625rem;
  }
  .f18 {
    font-size: 1.125rem;
  }
  .mainColor {
    color: #6d4a2f;
  }
  .subColor {
    color: #c3a76c;
  }
</style>
